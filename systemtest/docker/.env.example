# Copy to .env and adjust values before running docker compose.

BAMBOO_PORT=6990
BAMBOO_USERNAME=admin
BAMBOO_PASSWORD=admin
BAMBOO_SERVER_TIMEOUT=2400
BAMBOO_BUILD_TIMEOUT=900

# Path inside the Linux container used for the Bamboo MATLAB capability.
MATLAB_PATH=/opt/matlab-batch-adapter
REAL_MATLAB_ROOT=/opt/matlab/R2026a
MATLAB_BAMBOO_CAPABILITY=MATLAB R2026a

# Used by compose.with-matlab.yml to install MATLAB into the Docker image.
MATLAB_RELEASE=R2026a
MATLAB_INSTALL_ROOT=/opt/matlab
MATLAB_BATCH_ADAPTER_ROOT=/opt/matlab-batch-adapter
MATLAB_PRODUCTS=MATLAB

# MATLAB license configuration for the container. TeamCity-style batch tokens
# are passed through MLM_LICENSE_TOKEN and consumed by matlab-batch.
MLM_LICENSE_TOKEN=

# For a license server, use a value such as 27000@host.docker.internal or
# 27000@your-license-server and point MATLAB_PATH at REAL_MATLAB_ROOT.
MLM_LICENSE_FILE=
MW_LICENSE_FILE=
MATHWORKS_LICENSE_FILE=

# Optional. Used only with compose.license-file.yml.
# MATLAB_LICENSE_FILE_HOST=C:\path\to\license.dat

# Optional. Required only when using compose.matlab-volume.yml.
# This must point to a Linux MATLAB installation, not a Windows MATLAB install.
# MATLAB_HOST_ROOT=/absolute/path/to/linux/MATLAB/R2026a
